{
  "name": "haraka-plugin-redis",
  "version": "2.1.0",
  "description": "Redis plugin for Haraka & other plugins to inherit from",
  "main": "index.js",
  "files": [
    "config"
  ],
  "dependencies": {
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@haraka/eslint-config": "^3.0.0",
    "haraka-test-fixtures": "^1.7.0"
  },
  "scripts": {
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint *.js test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "qlty": "qlty smells --all",
    "test": "node --test test/*.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=package.json --test-coverage-exclude=test/*.js test/*.js",
    "test:coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info test/*.js",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haraka/haraka-plugin-redis.git"
  },
  "keywords": [
    "haraka",
    "haraka-plugin",
    "mail",
    "smtp",
    "redis"
  ],
  "author": "Matt Simerson <matt@tnpi.net>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haraka/haraka-plugin-redis/issues"
  },
  "homepage": "https://github.com/haraka/haraka-plugin-redis#readme",
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}
